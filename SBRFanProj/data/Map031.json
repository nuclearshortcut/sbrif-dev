{"id":1,"name":"Sheriff","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":121,"indent":0,"parameters":[83,83,0]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"This is ridiculous...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\"It's like this race has attracted all the miscreants in the"]},{"code":401,"indent":0,"parameters":["nation to this town!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\"I don't know how the government expects us to handle it "]},{"code":401,"indent":0,"parameters":["all! We've hardly left our frontier era! We only have a "]},{"code":401,"indent":0,"parameters":["few thousand residents!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\"That Steel should've taken this fiasco to San Francisco...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Mountain Tim: \"Sorry I couldn't be of more help sheriff.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"No, no, don't say that. You've done a lot for us"]},{"code":401,"indent":0,"parameters":["lawmen. And not just lately either!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Mt. Tim: \"I've asked around for some volunteers to help out."]},{"code":401,"indent":0,"parameters":["Everyone seems focused on their own problems though. I don't"]},{"code":401,"indent":0,"parameters":["know how many will show up.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"...Well, speak of the devil. Looks to me one's "]},{"code":401,"indent":0,"parameters":["showed up right now.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Mt. Tim: \"Well, I suppose there are some good hearts "]},{"code":401,"indent":0,"parameters":["around here after all!\""]},{"code":108,"indent":0,"parameters":["introductions"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"Listen... Mt. Tim thinks you're alright, but to me"]},{"code":401,"indent":0,"parameters":["you're just another racer.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"I'll give you the 'privilege' of being a tempoary "]},{"code":401,"indent":0,"parameters":["deputy, but don't get yourself into anything you can't "]},{"code":401,"indent":0,"parameters":["handle!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"There's a list of problems on that there board. "]},{"code":401,"indent":0,"parameters":["Go on and take a look.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"But remember! Don't bite off more than you can "]},{"code":401,"indent":0,"parameters":["chew.\""]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Sheriff: \"Go look over the board. If you ain't gonna help, "]},{"code":401,"indent":0,"parameters":["make yourself scarce.\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["Mt. Tim: \"And make sure to take care of that horse now! "]},{"code":401,"indent":0,"parameters":["Otherwise my win won't feel very honorable!\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":3},
{"id":2,"name":"MountainTim","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":3},
{"id":3,"name":"EV003","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":102,"indent":0,"parameters":[["1. Opium Den","2. Violent Gang","3. Prostitution"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"1. Opium Den"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'A lot of boats have been coming into the docks the past "]},{"code":401,"indent":1,"parameters":["few weeks, bringing over foreign racers and spectators.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'Smugglers have been using the commotion to sneak in opium.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'They likely have a hidden den somewhere in town where "]},{"code":401,"indent":1,"parameters":["they're hiding those drugs.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'They've only gotten sneakier the last time they were "]},{"code":401,"indent":1,"parameters":["exposed. They've gotta be right *under* our noses.'"]},{"code":121,"indent":1,"parameters":[86,86,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"2. Violent Gang"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'Everywhere has its fair share of criminality. Small town"]},{"code":401,"indent":1,"parameters":["like this though? The local troublemakers are well known"]},{"code":401,"indent":1,"parameters":["and don't act outside of your expectations.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'But that's changed as of late. The town has begun to grow"]},{"code":401,"indent":1,"parameters":["a lot the past few years with that new hotel, the railroad,"]},{"code":401,"indent":1,"parameters":["and all this chaos surrounding the race...'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'The crooks have gotten more organized and uncontrollable. "]},{"code":401,"indent":1,"parameters":["For the last few days, a gang's been going as far as"]},{"code":401,"indent":1,"parameters":["attacking newcomers and raiding private property.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'If we can't settle this, our worthiness of the badge will"]},{"code":401,"indent":1,"parameters":["come into question. If we cut off the head of the snake,"]},{"code":401,"indent":1,"parameters":["the robbers should at least reel in their crimes for a "]},{"code":401,"indent":1,"parameters":["while."]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'I'm betting they're based in the cesspit of this town, "]},{"code":401,"indent":1,"parameters":["Stingaree...\""]},{"code":121,"indent":1,"parameters":[85,85,0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[2,"3. Prostitution"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'We were willing to overlook the... illicit professions "]},{"code":401,"indent":1,"parameters":["some women took during the older days. But times have "]},{"code":401,"indent":1,"parameters":["changed.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'With eyes all over this town - two belonging to the "]},{"code":401,"indent":1,"parameters":["President himself - we need to shape up.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'But one particular saloon owner has been stubborn. He's "]},{"code":401,"indent":1,"parameters":["done a good job of masking his \"second business\". Not just"]},{"code":401,"indent":1,"parameters":["anyone is allowed to get involved with it anymore.'"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["'Without proof, there's nothing we can do to expose him.'"]},{"code":121,"indent":1,"parameters":[84,84,0]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":4,"y":2}
]
